### --- make ec2 automation --- ###
nano deploy.sh
#!/bin/bash
export GIT_SSH_COMMAND='ssh -i ~/.ssh/id_rsa_github -o StrictHostKeyChecking=no'
cd ~/auto-deploy-app
git pull origin main
pkill gunicorn
source venv/bin/activate
nohup gunicorn app:app --bind 0.0.0.0:8000 > deploy.log 2>&1 &
# - make executable
chmod +x deploy.sh
#- test manually with bash
./deploy.sh #- ./ means test this file in this directory
#-> this pulls latest code, starts gunicorn, and runs it in background with nohup


### --- after you change the app.py and push to github, run deploy.sh on ec2--- ###
#- this will pull the latest code and restart the app with new changes
git add .    # this adds all changes to staging
git commit -m "Test auto deploy"     # this commits the changes with a message
git push origin main    # this pushes the changes to GitHub
#- ec2
bash deploy.sh

